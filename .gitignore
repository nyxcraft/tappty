__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.venv/
venv/
*.png
# committed gallery images (generated by gh-pages/screenshots.py)
!docs/media/*.png
# the built site is committed too (below), so don't let *.png hide its copied images
!gh-pages/public/**/*.png
.ruff_cache/

# Built docs site -- generated by gh-pages/build_site.py. It is COMMITTED (so the Apache alias
# at /tappty/ serves the current build straight from a checkout) and kept in sync by the
# .githooks/pre-commit hook; CI verifies it isn't stale. The Pages workflow still rebuilds it
# fresh on deploy, so the published site never depends on the committed copy.

# AI assistant / tool working directories (not part of the project)
.agents/
.claude/
.codex
.codex/
.playwright-mcp/
